##
## Optionally configure the LTR structural identification pipeline.
##
sub configure_ltr_pipeline {
  section_header("LTR Structural Identification Pipeline  (optional)");
  print "\n  RepeatModeler can use an LTR structural pipeline to identify\n";
  print "  LTR retrotransposons with greater sensitivity. Requires:\n";
  print "  GenomeTools, LTR_Retriever (v2.9.0), MAFFT, and NINJA.\n\n";

  # If all four are already configured and valid, offer to keep them
  my @ltr_keys = qw( GENOMETOOLS_DIR LTR_RETRIEVER_DIR MAFFT_DIR NINJA_DIR );
  my $all_valid = 1;
  for my $k ( @ltr_keys ) {
    $all_valid = 0 unless RepModelConfig::validateParam($k);
  }

  if ( $all_valid ) {
    print "  LTR pipeline currently configured:\n";
    for my $k ( @ltr_keys ) {
      printf "    %-18s  %s\n", $k, $config->{$k}->{'value'};
    }
    print "\n";
    if ( prompt_yn( "Keep this LTR pipeline configuration?", "y" ) ) {
      for my $k ( @ltr_keys ) {
        status_ok( "$k: " . $config->{$k}->{'value'} );
      }
      return;
    }
    print "\n";
  }

  unless ( prompt_yn( "Configure the LTR pipeline?", "n" ) ) {
    status_info("LTR pipeline not configured (optional).");
    return;
  }

  print "\n";

  _configure_dir(
    key   => 'GENOMETOOLS_DIR',
    label => 'GenomeTools',
    desc  => 'GenomeTools provides structural LTR detection (gt ltrharvest).',
    url   => 'http://genometools.org/',
  );

  _configure_dir(
    key   => 'LTR_RETRIEVER_DIR',
    label => 'LTR_Retriever',
    desc  => 'LTR_Retriever identifies and classifies LTR elements. (v2.9.0)',
    url   => 'https://github.com/oushujun/LTR_retriever',
    version_check => sub {
      my $val = $config->{'LTR_RETRIEVER_DIR'}->{'value'};
      my $ver = "";
      if ( open( my $fh, "<", "$val/LTR_retriever" ) ) {
        while ( <$fh> ) {
          if ( /^my\s+\$version\s*=\s*"(\S+)"/ ) { $ver = $1; last; }
        }
        close $fh;
      }
      if ( $ver ) {
        unless ( $ver eq "v2.9.0" ) {
          die "\n  ERROR: LTR_Retriever $ver is not the required version. "
            . "Please use v2.9.0.\n\n";
        }
        status_info("Version: $ver");
      }
    },
  );

  _configure_dir(
    key   => 'MAFFT_DIR',
    label => 'MAFFT',
    desc  => 'MAFFT performs multiple sequence alignment.',
    url   => 'https://mafft.cbrc.jp/alignment/software/',
  );

  _configure_dir(
    key   => 'NINJA_DIR',
    label => 'NINJA',
    desc  => 'NINJA performs rapid phylogenetic analysis.',
    url   => 'https://github.com/TravisWheelerLab/NINJA',
  );
}

##
## Extract FamDB libraries and build BLAST databases in Libraries/.
## Called once at configure time so RepeatClassifier can rely on them.
##
## Print a final summary of the installed configuration.
##
sub print_summary {
  my $w = 62;
  print "\n" . "=" x $w . "\n";
  printf " %-*s\n", $w - 2, " Configuration Summary";
  print "=" x $w . "\n\n";

  my @core = (
    [ 'REPEATMASKER_DIR', 'RepeatMasker'   ],
    [ 'FAMDB_DIR',        'FamDB'          ],
    [ 'RMBLAST_DIR',      'RMBlast'        ],
    [ 'RSCOUT_DIR',       'RepeatScout'    ],
    [ 'RECON_DIR',        'RECON'          ],
    [ 'REPEATAFTERME_DIR','RepeatAfterMe'  ],
    [ 'TRF_DIR',          'TRF'            ],
    [ 'CDHIT_DIR',        'CD-HIT'         ],
    [ 'UCSCTOOLS_DIR',    'UCSC TwoBit'    ],
  );

  for my $item ( @core ) {
    my ( $key, $label ) = @$item;
    my $val = $config->{$key}->{'value'} // "";
    if ( $val && RepModelConfig::validateParam($key) ) {
      printf "  %-16s  %s\n", "$label:", $val;
    }
    else {
      printf "  %-16s  (not configured)\n", "$label:";
    }
  }

  # FamDB database details from famdb.py info
  if ( RepModelConfig::validateParam('FAMDB_DIR') ) {
    my $famdb_dir = $config->{'FAMDB_DIR'}->{'value'};
    my $info = `$famdb_dir/famdb.py info 2>/dev/null` // "";
    if ( $info ) {
      my ( $db_name, $db_ver, $db_date, $db_count );
      $db_name  = $1 if $info =~ /^Database\s*:\s*(\S.*)/m;
      $db_ver   = $1 if $info =~ /^Version\s*:\s*(\S.*)/m;
      $db_date  = $1 if $info =~ /^Date\s*:\s*(\S.*)/m;
      $db_count = $1 if $info =~ /^Total consensus sequences present\s*:\s*(\d+)/m;
      $db_count = $1 if !$db_count && $info =~ /^Total HMMs present\s*:\s*(\d+)/m;
      if ( $db_name ) {
        printf "  %-16s  %s %s (%s)\n", "",
            $db_name, $db_ver // "", $db_date // "";
        printf "  %-16s  %s families\n", "",
            _commify($db_count) if $db_count;
      }
    }
  }

  # Optional LTR pipeline tools
  my @ltr_keys = qw( GENOMETOOLS_DIR LTR_RETRIEVER_DIR MAFFT_DIR NINJA_DIR );
  my $any_ltr  = 0;
  for my $k ( @ltr_keys ) {
    $any_ltr = 1 if RepModelConfig::validateParam($k);
  }

  if ( $any_ltr ) {
    my %ltr_labels = (
      GENOMETOOLS_DIR   => 'GenomeTools',
      LTR_RETRIEVER_DIR => 'LTR_Retriever',
      MAFFT_DIR         => 'MAFFT',
      NINJA_DIR         => 'NINJA',
    );
    print "\n  LTR Pipeline:\n";
    for my $k ( @ltr_keys ) {
      if ( RepModelConfig::validateParam($k) ) {
        printf "  %-16s  %s\n", "  $ltr_labels{$k}:", $config->{$k}->{'value'};
      }
    }
  }

  print "\n" . "=" x $w . "\n";
  printf " %-*s\n", $w - 2, " RepeatModeler v$version is configured and ready.";
  print "=" x $w . "\n\n";
}

sub _commify {
  my $n = reverse( $_[0] // 0 );
  $n =~ s/(\d{3})(?=\d)/$1,/g;
  return scalar reverse $n;
}

1;
